# DeepSeek API (OpenAI compatible)
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL_NAME=deepseek-chat
OPENAI_USER_AGENT=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_TOKENS=2048
OPENAI_RESPONSE_FORMAT_JSON=1
AGENT1_TODAY=

# NebulaGraph HTTP API（文档: https://graph.automed.cn/apidoc）
GRAPH_API_BASE_URL=https://graph.automed.cn
GRAPH_API_KEY=your_graph_api_key_here
GRAPH_API_SPACE=your_space
GRAPH_API_AUTO_SPACE=1

# 后端 API 服务
API_PORT=8000

#数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=yuanxi
